{
	"name": "scrapegraph-js",
	"version": "2.0.0",
	"description": "Official ScrapeGraphAI SDK",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "rm -rf dist && bun build ./src/index.ts --outfile ./dist/index.js --format esm --target node && bun build ./src/index.ts --outfile ./dist/index.cjs --format cjs --target node && bunx tsc --project tsconfig.json --emitDeclarationOnly",
		"lint": "biome check .",
		"format": "biome format . --write",
		"check": "tsc --noEmit && biome check .",
		"test": "bun test",
		"type-check": "tsc --noEmit"
	},
	"keywords": [
		"scraping",
		"ai",
		"scrapegraph",
		"typescript",
		"sdk",
		"web-scraping",
		"api"
	],
	"author": "ScrapeGraph Team",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ScrapeGraphAI/scrapegraph-js.git"
	},
	"homepage": "https://scrapegraphai.com",
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist"
	],
	"peerDependencies": {
		"zod": "^3.0.0 || ^4.0.0"
	},
	"peerDependenciesMeta": {
		"zod": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/bun": "^1.3.9",
		"@types/node": "^22.13.1",
		"typescript": "^5.8.2",
		"zod": "^4.1.12"
	}
}
